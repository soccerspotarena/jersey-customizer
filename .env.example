# ── Shopify App Credentials ────────────────────────────────────────────────────
# Found in Shopify Partner Dashboard → Apps → <your app> → API credentials

# The public Client ID (safe to expose in the frontend via SHOPIFY_API_KEY)
SHOPIFY_API_KEY="your_client_id_here"

# The secret Client Secret — never expose this in client-side code
SHOPIFY_API_SECRET="your_client_secret_here"

# OAuth scopes the app requests — must match shopify.app.toml [access_scopes]
SCOPES="read_products,write_products,read_orders,write_orders,read_customers"

# The public HTTPS URL where this app is hosted (no trailing slash).
# Local dev:  your Cloudflare tunnel URL, e.g. https://abc123.trycloudflare.com
# Production: your Railway app URL, e.g. https://jersey-customizer.up.railway.app
SHOPIFY_APP_URL="https://your-app.up.railway.app"

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Railway:    automatically injected when you add a PostgreSQL plugin —
#             copy it from Railway dashboard → PostgreSQL service → Connect tab.
# Local dev:  postgresql://<user>:<password>@localhost:5432/<dbname>
#             Example: postgresql://postgres:postgres@localhost:5432/jersey_customizer_dev
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── AI / Image Processing APIs ─────────────────────────────────────────────────
# Anthropic Claude — used for AI-assisted features
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI — used for image generation / other AI features
# https://platform.openai.com → API keys
OPENAI_API_KEY="sk-proj-..."

# Remove.bg — used for background removal on uploaded logos/sponsors
# https://www.remove.bg/dashboard#api-key
REMOVEBG_API_KEY="your_removebg_key_here"

# ── Runtime ────────────────────────────────────────────────────────────────────
# Set automatically by Railway. Do not set this manually in Railway dashboard.
# For local dev, remix-serve defaults to 3000 when PORT is unset.
# PORT=3000

# Set to "production" on Railway. Set automatically by Railway.
# NODE_ENV=production
